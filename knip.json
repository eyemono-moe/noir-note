{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/index.{js,ts,tsx}"],
  "postcss": true,
  "tags": ["-lintignore"],
  "unocss": true,
  "vite": true,
  "vitest": true,
  "ignoreDependencies": [
    "@iconify-json/material-symbols",
    "eslint-plugin-solid",
    "jsdom",
    "wrangler"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["src/editor/shiki.bundle.ts"],
  "exclude": ["catalog"]
}
