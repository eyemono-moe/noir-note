{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "noir-note",
  "compatibility_date": "2026-04-18",
  "observability": {
    "enabled": true,
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application",
  },
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "custom_domain": true,
      "pattern": "md.eyemono.moe",
    },
  ],
  "preview_urls": true,
  "workers_dev": true,
}
