{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "noir-note",
  "compatibility_date": "2026-04-18",
  "observability": {
    "enabled": true,
  },
  "assets": {
    "directory": "dist",
  },
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "custom_domain": true,
      "pattern": "md.eyemono.moe",
    },
  ],
}
